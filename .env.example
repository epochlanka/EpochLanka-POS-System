# Database Configuration
# Set USE_POSTGRES to "true" to switch to PostgreSQL schema/driver in prisma.config.ts
USE_POSTGRES="false"

# Local SQLite connection URL (used by default when USE_POSTGRES is false)
DATABASE_URL_LOCAL="file:./dev.db"

# Cloud PostgreSQL connection URL (used when USE_POSTGRES is true or NODE_ENV is production)
DATABASE_URL_CLOUD="postgresql://username:password@localhost:5432/epochlanka_pos?schema=public"
